{
  "name": "cipherpoker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev":           "vite --port=3000 --host=0.0.0.0",
    "build":         "tsc -b && vite build",
    "lint":          "tsc --noEmit",
    "preview":       "vite preview",
    "clean":         "rm -rf dist",
    "compile":       "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat compile",
    "test:contracts":"cross-env TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat test",
    "deploy:sepolia":"cross-env TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat run scripts/deploy.cts --network eth-sepolia",
    "deploy:local":  "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat run scripts/deploy.cts --network hardhat"
  },
  "dependencies": {
    "@cofhe/react":               "^0.4.0",
    "@cofhe/sdk":                 "^0.4.0",
    "@tanstack/react-query":      "^5.29.0",
    "clsx":                       "^2.1.0",
    "framer-motion":              "^11.0.0",
    "lucide-react":               "^0.344.0",
    "react":                      "^18.2.0",
    "react-dom":                  "^18.2.0",
    "tailwind-merge":             "^2.2.1",
    "viem":                       "^2.21.0",
    "wagmi":                      "^2.12.0",
    "zustand":                    "^5.0.0"
  },
  "devDependencies": {
    "@cofhe/hardhat-plugin":                     "^0.4.0",
    "@fhenixprotocol/cofhe-contracts":           "^0.1.0",
    "@fhenixprotocol/cofhe-mock-contracts":      "^0.3.1",
    "@nomicfoundation/hardhat-chai-matchers":    "^2.0.0",
    "@nomicfoundation/hardhat-ethers":           "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers":  "^1.0.0",
    "@nomicfoundation/hardhat-toolbox":          "^5.0.0",
    "@tailwindcss/vite":                         "^4.0.0",
    "@types/chai":                               "^4.3.0",
    "@types/mocha":                              "^10.0.0",
    "@types/node":                               "^20.0.0",
    "@types/react":                              "^18.2.66",
    "@types/react-dom":                          "^18.2.22",
    "@vitejs/plugin-react":                      "^4.2.1",
    "chai":                                      "^4.3.0",
    "cross-env":                                 "^10.1.0",
    "dotenv":                                    "^16.4.0",
    "ethers":                                    "^6.13.0",
    "hardhat":                                   "^2.22.0",
    "tailwindcss":                               "^4.0.0",
    "ts-node":                                   "^10.9.0",
    "tsx":                                       "^4.7.0",
    "typescript":                                "^5.2.2",
    "vite":                                      "^5.2.0"
  }
}
