{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist-hardhat"
  },
  "include": [
    "hardhat.config.cts",
    "scripts/**/*.cts",
    "scripts/**/*.ts",
    "test/**/*.cts",
    "test/**/*.ts"
  ],
  "exclude": [
    "src",
    "node_modules"
  ]
}
